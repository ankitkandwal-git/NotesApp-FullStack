# Example .env file for NotesApp backend (local development)

# Path to SQLite database file (optional)
DB_PATH=notes.db

# JWT secret key (required, use a strong random string in production)
JWT_SECRET=your-very-secret-key

# CORS origin (URL of your frontend, e.g., for local dev)
CORS_ORIGIN=http://localhost:5173

# Port (optional, Render sets this automatically in production)
PORT=5000
